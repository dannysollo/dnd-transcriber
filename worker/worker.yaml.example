server_url: https://your-dnd-transcriber.fly.dev
api_key: paste-key-from-campaign-settings
audio_dir: /path/to/audio/output
poll_interval: 30
# campaign_slug is optional — the worker will auto-discover it from your api_key.
# Only set this if you want to override auto-discovery.
# campaign_slug: your-campaign-slug
# whisper_model: turbo  # Uncomment to override the campaign's model setting

# ── Speaker Diarization (optional) ───────────────────────────────────────────
# Splits tracks with multiple speakers (e.g. two people on the same mic).
# Requires: pip install pyannote.audio
# And a HuggingFace token with access to pyannote/speaker-diarization-3.1
# Accept terms at: https://huggingface.co/pyannote/speaker-diarization-3.1
#
# hf_token: hf_xxxxxxxxxxxxxxxxxxxx
# diarize_tracks:           # Diarize only these tracks (partial filename match)
#   - dannysollo
# # diarize_all: true       # Or diarize every track

# ── Craig Watcher (optional) ──────────────────────────────────────────────────
# Uncomment to enable automatic recording download when Craig DMs you.
# discord_token: YOUR_DISCORD_USER_TOKEN  # Your personal Discord token (not a bot token)
# session_name_format: "{date}"           # Options: {date}, {date}-{channel}, {recording_id}
# craig_channel_filter:                   # Optional: only process recordings from specific guilds
#   - "1113899568355098775"
